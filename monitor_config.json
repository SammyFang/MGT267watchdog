{
  "crawl": {
    "interval_minutes": 60,
    "timezone": "America/Los_Angeles",
    "entry_url": "https://op.responsive.net/sc/riverside267/entry.html",
    "login_url": "https://op.responsive.net/SupplyChain/SCAccess",
    "warehouse_inventory_url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+inventory&data=WH1",
    "standing_url": "https://op.responsive.net/SupplyChain/SCStanding",
    "plot_sources": [
      {
        "id": "warehouse_inventory",
        "section": "Warehouse",
        "label": "Inventory",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+inventory&data=WH1"
      },
      {
        "id": "warehouse_shipments",
        "section": "Warehouse",
        "label": "Shipments",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+shipments&data=SHIP1SEG1"
      },
      {
        "id": "factory_wip",
        "section": "Factory",
        "label": "WIP",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+wip&data=WIP1"
      },
      {
        "id": "hq_demand",
        "section": "Headquarters",
        "label": "Demand",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+demand&data=DEMAND1"
      },
      {
        "id": "hq_lost_demand",
        "section": "Headquarters",
        "label": "Lost Demand",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+lost+demand&data=LOST1"
      },
      {
        "id": "hq_cash_balance",
        "section": "Headquarters",
        "label": "Cash Balance",
        "url": "https://op.responsive.net/SupplyChain/SCPlotk?submit=plot+cash+balance&data=BALANCE"
      }
    ]
  },
  "credentials": {
    "team_id_env": "SC_TEAM_ID",
    "password_env": "SC_PASSWORD",
    "institution_env": "SC_INSTITUTION",
    "default_institution": "riverside267"
  },
  "monitor": {
    "target_team": "group7",
    "warehouse_inventory_threshold": 450,
    "warning_minutes": 15,
    "send_report_every_run": true,
    "gap_percentage_formula": "(target_cash - team_cash) / team_cash * 100",
    "alert_rules": [
      {
        "id": "warehouse_inventory_high",
        "label": "Warehouse inventory high",
        "metric": "warehouse_inventory:warehouse",
        "operator": ">=",
        "threshold": 450,
        "severity": "critical",
        "channels": ["warning", "hourly"],
        "message": "Warehouse inventory is above the high-stock threshold."
      },
      {
        "id": "warehouse_stockout_risk",
        "label": "Warehouse stockout risk",
        "metric": "warehouse_inventory:warehouse",
        "operator": "<=",
        "threshold": 50,
        "severity": "critical",
        "channels": ["warning", "hourly"],
        "message": "Warehouse inventory is very low; stockout risk is elevated."
      },
      {
        "id": "lost_demand_detected",
        "label": "Lost demand detected",
        "metric": "hq_lost_demand:Calopeia",
        "operator": ">",
        "threshold": 0,
        "severity": "critical",
        "channels": ["hourly"],
        "message": "Lost demand is present; inspect supply and shipment timing."
      },
      {
        "id": "lost_demand_rate_high",
        "label": "Lost demand rate high",
        "metric": "derived:lost_demand_rate",
        "operator": ">=",
        "threshold": 20,
        "severity": "critical",
        "channels": ["hourly"],
        "message": "Lost demand is high relative to demand."
      },
      {
        "id": "days_of_cover_low",
        "label": "Days of cover low",
        "metric": "derived:days_of_cover",
        "operator": "<",
        "threshold": 1,
        "severity": "warning",
        "channels": ["hourly"],
        "message": "Warehouse coverage is below one demand day."
      },
      {
        "id": "days_of_cover_high",
        "label": "Days of cover high",
        "metric": "derived:days_of_cover",
        "operator": ">",
        "threshold": 5,
        "severity": "warning",
        "channels": ["hourly"],
        "message": "Warehouse coverage is high; watch inventory carrying cost."
      },
      {
        "id": "shipments_below_demand",
        "label": "Shipments below demand",
        "metric": "derived:shipment_to_demand_ratio",
        "operator": "<",
        "threshold": 0.8,
        "severity": "warning",
        "channels": ["hourly"],
        "message": "Shipments are below demand; check fulfillment capacity."
      },
      {
        "id": "cash_lead_narrow",
        "label": "Cash lead narrow",
        "metric": "derived:cash_lead_percent_vs_nearest",
        "operator": "<",
        "threshold": 5,
        "severity": "warning",
        "channels": ["hourly"],
        "message": "Cash lead over the nearest competitor is narrowing."
      }
    ],
    "metric_thresholds": {
      "warehouse_inventory:mail": {
        "label": "Warehouse mail inventory",
        "min": null,
        "max": null
      },
      "warehouse_inventory:truck": {
        "label": "Warehouse truck inventory",
        "min": null,
        "max": null
      },
      "warehouse_shipments:Calopeia": {
        "label": "Warehouse shipments",
        "min": null,
        "max": null
      },
      "factory_wip:Calopeia": {
        "label": "Factory WIP",
        "min": null,
        "max": null
      },
      "hq_demand:Calopeia": {
        "label": "Headquarters demand",
        "min": null,
        "max": null
      },
      "hq_lost_demand:Calopeia": {
        "label": "Headquarters lost demand",
        "min": null,
        "max": null
      },
      "hq_cash_balance:value": {
        "label": "Headquarters cash balance",
        "min": null,
        "max": null
      }
    }
  },
  "ai": {
    "enabled": true,
    "provider": "gemini",
    "api_key_env": "GEMINI_API_KEY",
    "model": "gemini-2.5-flash",
    "recommendation_language": "English",
    "max_suggestions": 4
  },
  "email": {
    "enabled": true,
    "recipients": [
      "950154@gmail.com",
      "wgong009@ucr.edu",
      "hhuan238@ucr.edu",
      "yfang097@ucr.edu"
    ],
    "subject_prefix": "MGT267 Warehouse Watchdog",
    "attach_excel": true,
    "footer": {
      "text": "Developed by Yung-Sian Fang",
      "url": "https://sammyfang.tw"
    }
  },
  "output": {
    "state_dir": ".monitor-state",
    "latest_json": ".monitor-state/latest.json",
    "history_csv": ".monitor-state/history.csv",
    "warehouse_inventory_csv": ".monitor-state/warehouse_inventory_latest.csv",
    "standing_gaps_csv": ".monitor-state/standing_gaps_latest.csv",
    "operational_snapshot_csv": ".monitor-state/operational_snapshot_latest.csv",
    "data_workbook_xlsx": ".monitor-state/supply_chain_data_latest.xlsx",
    "email_delivery_json": ".monitor-state/email_delivery_latest.json"
  },
  "excel": {
    "exponential_smoothing_alpha": 0.3
  }
}
